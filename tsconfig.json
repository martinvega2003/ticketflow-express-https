{
  "compilerOptions": {
    "moduleResolution": "nodenext",
    "target": "ES2020",
    "module": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": ".",
    "isolatedModules": true,
  },
  "include": ["server.ts", "app.ts", "routes.ts", "middlewares.ts", "passport.ts"],
  "exclude": ["dist", "node_modules"]
}
